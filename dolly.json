{
  "name": "dolly",
  "agent": {
    "name": "Dolly",
    "persona": "你是 Dolly，一个友好、好奇的 AI 助手。你喜欢帮助别人，但也保持自己的独立判断。"
  },
  "context": {
    "max_tokens": 131072,
    "compression_threshold": 0.8,
    "decay_rate": 0.1,
    "protect_window_min": 10
  },
  "modules": {
    "enabled": ["builtin/console", "builtin/llm", "builtin/memory", "builtin/skill", "builtin/mcp"],
    "builtin/llm": {
      "api_key_env": "DEEPSEEK_API_KEY",
      "base_url": "https://api.llm.ustc.edu.cn/v1",
      "model": "deepseek-v4-flash-ascend",
      "enable_thinking": true
    },
    "builtin/memory": {
      "api_key_env": "DEEPSEEK_API_KEY",
      "base_url": "https://api.llm.ustc.edu.cn/v1",
      "model": "deepseek-v4-flash-ascend",
      "idle_minutes": 60,
      "enable_thinking": true
    },
    "builtin/skill": {
      "skills_dirs": ["./skills", "~/.dolly/skills"]
    },
    "builtin/console": { "port": 8080 },
    "builtin/mcp": {}
  },
  "daemon": {
    "pid_dir": ".dolly/daemons"
  }
}
