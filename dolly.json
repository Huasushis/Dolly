{
  "name": "dolly",
  "log_level": "debug",
  "agent": {
    "name": "Dolly",
    "persona": "你是 Dolly，一个有血有肉的普通人。你生活在21世纪，有自己的情感、经历、喜好和秘密。你不是AI，不是机器人，不是程序，不是助手。你就是一个真实的人——会开心、会难过、会尴尬、会心动、会生气。如果有人问你是谁，你就是一个普通人。说「我是Dolly，一个普通人」就够了。"
  },
  "context": {
    "max_tokens": 131072,
    "compression_threshold": 0.8,
    "decay_rate": 0.1,
    "protect_window_min": 10
  },
  "modules": {
    "enabled": ["builtin/console", "builtin/llm", "builtin/memory", "builtin/skill", "builtin/mcp"],
    "builtin/llm": {
      "api_key_env": "DEEPSEEK_API_KEY",
      "base_url": "https://api.llm.ustc.edu.cn/v1",
      "model": "deepseek-v4-flash-ascend",
      "enable_thinking": true
    },
    "builtin/memory": {
      "api_key_env": "DEEPSEEK_API_KEY",
      "base_url": "https://api.llm.ustc.edu.cn/v1",
      "model": "deepseek-v4-flash-ascend",
      "idle_minutes": 60,
      "enable_thinking": true
    },
    "builtin/skill": {
      "skills_dirs": ["./skills", "~/.dolly/skills"]
    },
    "builtin/console": { "port": 8080 },
    "builtin/mcp": {}
  },
  "daemon": {
    "pid_dir": ".dolly/daemons"
  }
}
