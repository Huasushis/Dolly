// Shared types for Dolly base agent

// === Event Bus Types ===

type InjectionEvent = {
    "id": String("unique injection id for lifecycle management"),
    "content": String("text to inject into context"),
    "target": String("'background' | 'working' — where to inject"),
    "priority": Int("lower = higher priority, 0 is system-level")
}

type MonitorAction = {
    "action": String("'inject' | 'block' | 'pass' | 'remove'"),
    "injection_id": String("optional, id of injection to remove"),
    "payload": String("optional, text content to pass along")
}

type OutputChunk = {
    "text": String("a chunk of LLM output text"),
    "timestamp": Float("unix timestamp of generation")
}

// === Context Types ===

type ContextFrame = {
    "id": String("unique frame id"),
    "role": String("'system' | 'user' | 'assistant' | 'injection'"),
    "content": String("frame text content"),
    "timestamp": Float("when this frame was added"),
    "distance_from_end": Int("position in context, 0 = most recent"),
    "injection_id": String("optional, links to injection for removal"),
    "pinned": Bool("if true, protected from automatic removal")
}

// === Memory Types ===

type ShortTermMemoryEntry = {
    "id": String("matches injection id"),
    "content": String("the remembered content"),
    "relevance_score": Float("estimated relevance to current conversation, 0-1"),
    "created_at": Float("unix timestamp"),
    "last_accessed": Float("unix timestamp")
}

type LongTermMemoryEntry = {
    "id": String("unique entry id"),
    "content": String("summarized content"),
    "keywords": List<String("keyword for retrieval")>,
    "source_day": String("ISO date of source log"),
    "created_at": Float("unix timestamp")
}

// === Configuration Types ===

type LLMConfig = {
    "api_key": String("API key"),
    "base_url": String("API base URL"),
    "model": String("model name")
}

type ContextConfig = {
    "max_tokens": Int("maximum token capacity"),
    "compression_threshold": Float("0-1, trigger compression when usage > this")
}

type DollyConfig = {
    "main_llm": {
        "api_key": String("primary API key"),
        "base_url": String("primary API base URL"),
        "model": String("primary model name")
    }("primary agent LLM config"),
    "aux_llm": {
        "api_key": String("auxiliary API key"),
        "base_url": String("auxiliary API base URL"),
        "model": String("auxiliary model name")
    }("auxiliary LLM for memory, semantic detection"),
    "context": ContextConfig,
    "injection_modules": List<String("path to injection module")>,
    "monitor_modules": List<String("path to monitor module")>,
    "long_term_memory_path": String("storage path for long-term memory")
}
