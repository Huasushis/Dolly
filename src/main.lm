// Dolly — base agent prototype for multi-agent collaborative network testing
import "types.lm" as t

// === Core Infrastructure ===

module ContextManager {
    setup: "initialize empty context with background prompt from DollyConfig"

    interface: {
        "get_context": { } -> { "frames": List<t.ContextFrame> }
        "add_frame": { "frame": t.ContextFrame } -> { "ok": String, "frame_id": String }
        "remove_frame": { "frame_id": String } -> { "ok": String }
        "remove_by_injection_id": { "injection_id": String } -> { "removed": Int }
        "estimate_tokens": { } -> { "count": Int, "ratio": Float }
        "pin_frame": { "frame_id": String } -> { "ok": String }
    }

    logic: "Maintain ordered list of ContextFrames, background prompt is pinned frame[0], estimate tokens as chars/4"
}

module EventBus {
    setup: "initialize empty listener registry"

    interface: {
        "emit": { "event": String, "data": {} } -> { "ok": String }
        "on": { "event": String, "handler_id": String } -> { "ok": String }
        "off": { "event": String, "handler_id": String } -> { "ok": String }
    }

    logic: "Simple pub/sub event bus for injection/monitor communication"
}

module LLMClient {
    setup: "initialize OpenAI-compatible client pointed at DeepSeek API"

    interface: {
        "chat": { "messages": List<{ "role": String, "content": String }> } -> { "response": String }
        "chat_stream": { "messages": List<{ "role": String, "content": String }> } -> { "ok": String }
    }

    logic: "Wrap OpenAI SDK chat completions API, stream mode emits chunks via EventBus as llm.output_chunk"
}

// === Injection System ===

module InjectionRegistry {
    setup: "load default injection modules from DollyConfig paths"

    interface: {
        "register": { "module_path": String } -> { "ok": String, "module_id": String }
        "unregister": { "module_id": String } -> { "ok": String }
        "reload": { "module_id": String } -> { "ok": String }
        "get_pending": { "context_frames": List<t.ContextFrame> } -> { "injections": List<t.InjectionEvent> }
        "list_modules": { } -> { "modules": List<{ "id": String, "path": String }> }
    }

    logic: "Manage injection module lifecycle, collect pending injections from all modules, support hot-reload via chokidar file watcher"
}

module ContextCompressor {
    setup: "initialize with random seed for probabilistic forgetting"

    interface: {
        "compress": { "frames": List<t.ContextFrame>, "threshold": Float } -> { "removed_ids": List<String> }
    }

    logic: "When context exceeds threshold, probabilistically forget older frames — removal probability equals distance_from_end / total_frames, pinned frames never removed"
}

// === Monitor System ===

module MonitorRegistry {
    setup: "load default monitor modules from DollyConfig paths"

    interface: {
        "register": { "module_path": String } -> { "ok": String, "module_id": String }
        "unregister": { "module_id": String } -> { "ok": String }
        "reload": { "module_id": String } -> { "ok": String }
        "process_output": { "chunk": t.OutputChunk } -> { "actions": List<t.MonitorAction> }
        "list_modules": { } -> { "modules": List<{ "id": String, "path": String }> }
    }

    logic: "Run all monitor modules on each output chunk, collect actions, if any monitor has blocking=true then pause LLM output"
}

// === Memory System ===

module ShortTermMemory {
    setup: "initialize empty entry map, subscribe to EventBus for memory.forget_tag events"

    interface: {
        "track": { "entry": t.ShortTermMemoryEntry } -> { "ok": String }
        "mark_unused": { "id": String } -> { "ok": String }
        "get_active": { } -> { "entries": List<t.ShortTermMemoryEntry> }
        "prune_stale": { "max_age_seconds": Float } -> { "removed": Int }
    }

    logic: "Track injections as memory entries, listen for FORGET tags from monitors to remove entries, periodically prune stale entries"
}

module LongTermMemory {
    setup: "initialize JSON file-based storage at configured path, load existing keyword index"

    interface: {
        "archive_day": { "context_log": List<t.ContextFrame> } -> { "ok": String, "archived_count": Int }
        "summarize": { "raw_log": List<t.ContextFrame> } -> { "entries": List<t.LongTermMemoryEntry> }
        "search": { "query": String, "top_k": Int } -> { "results": List<t.LongTermMemoryEntry> }
        "inject_relevant": { "query": String } -> { "injections": List<t.InjectionEvent> }
    }

    logic: "Daily archiving of context log, aux LLM summarizes into keyword-indexed entries, keyword search for retrieval, frequently accessed entries promoted to background"
}

// === Main Orchestrator ===

module Main {
    actor context_mgr: ContextManager
    actor event_bus: EventBus
    actor llm_client: LLMClient
    actor injection_registry: InjectionRegistry
    actor monitor_registry: MonitorRegistry
    actor short_term_memory: ShortTermMemory
    actor long_term_memory: LongTermMemory
    actor compressor: ContextCompressor

    setup: "Load .env config via dotenv, initialize all subsystems, hot-load injection/monitor modules, inject default system prompt, start REPL on stdin"

    interface: {
        "run": { "user_input": String } -> { "response": String }
        "shutdown": { } -> { "ok": String }
    }

    logic: "Main loop: receive input, run injections, build context, stream LLM response through monitors, handle tool calls, compress when near capacity, archive daily"
}
