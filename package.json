{
  "name": "dolly",
  "version": "0.1.0",
  "description": "Base agent prototype for multi-agent collaborative network testing",
  "type": "module",
  "main": "src/main.ts",
  "bin": {
    "dolly": "bin/dolly.js"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node --import tsx/esm bin/dolly.js run",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.31.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "async-mutex": "^0.5.0",
    "chokidar": "^4.0.0",
    "dotenv": "^16.4.0",
    "mcp-server-commands": "^0.8.2",
    "openai": "^4.70.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tavily-mcp": "^0.2.19",
    "ws": "^8.20.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
